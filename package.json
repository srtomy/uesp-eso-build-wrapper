{
  "name": "uesp-eso-build-wrapper",
  "version": "0.1.0",
  "description": "Node.js wrapper around the UESP ESO Build Editor math engine. Calculate Elder Scrolls Online character stats (Health, Magicka, Stamina, mitigation, crit, etc.) without rewriting any game formulas.",
  "keywords": [
    "elder-scrolls-online",
    "eso",
    "uesp",
    "build-editor",
    "character-stats",
    "eso-build",
    "game",
    "wrapper"
  ],
  "license": "MIT",
  "author": {
    "name": "Tarcisio Scotta",
    "email": "tarcisioscotta2@gmail.com",
    "url": "https://github.com/srtomy"
  },
  "homepage": "https://github.com/srtomy/uesp-eso-build-wrapper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srtomy/uesp-eso-build-wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/srtomy/uesp-eso-build-wrapper/issues"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "main": "dist/lib/eso-engine/index.js",
  "types": "dist/lib/eso-engine/index.d.ts",
  "sideEffects": true,
  "exports": {
    ".": {
      "import": "./dist/lib/eso-engine/index.js",
      "require": "./dist/lib/eso-engine/index.js",
      "types": "./dist/lib/eso-engine/index.d.ts"
    }
  },
  "files": [
    "dist",
    "vendor/uesp-esochardata/resources/esoEditBuild.js",
    "vendor/uesp-esochardata/resources/esobuilddata.js",
    "vendor/uesp-esochardata/LICENSE",
    "vendor/uesp-esolog/resources/esoskills.js",
    "vendor/uesp-esolog/LICENSE",
    "vendor/uesp-data/uesp-init-data.json",
    "THIRD_PARTY_NOTICES"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepublishOnly": "npm run build && npm run lint && node -e \"require('fs').existsSync('vendor/uesp-data/uesp-init-data.json')||process.exit(1)\"",
    "test": "vitest run",
    "test:explore": "ts-node --project tsconfig.scripts.json scripts/test-engine.ts",
    "test:build": "ts-node --project tsconfig.scripts.json scripts/test-build.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
